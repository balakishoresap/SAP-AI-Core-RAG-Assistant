{
  "name": "sap-ai-core-rag-assistant",
  "version": "1.0.0",
  "description": "RAG-based AI Assistant for SAP BTP using SAP AI Core and CAP",
  "repository": "https://github.com/balakishoresap/sap-ai-core-rag-assistant",
  "license": "Apache-2.0",
  "private": true,
  "dependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap-cloud-sdk/http-client": "^3",
    "@sap/cds": "^8",
    "@sap/xssec": "^3",
    "better-sqlite3": "^12.8.0",
    "express": "^4",
    "hdb": "^0.19",
    "passport": "^0.7"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.8.2",
    "@sap/ux-specification": "^1.124.18",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "cds build --production",
    "watch": "cds watch",
    "test": "node test/test-queries.js",
    "clean": "rimraf gen"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "admin"
            ]
          },
          "user": {
            "password": "user",
            "roles": []
          }
        }
      },
      "SAP_AI_CORE": {
        "kind": "rest",
        "credentials": {
          "destination": "SAP_AI_CORE",
          "path": "/v2"
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "sapux": [
    "app"
  ]
}
